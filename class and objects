#Aim: Write a that defines a Car class with attributes like make, model, and year, and methods like  start() to start the car and stop() to stop it
# Updated Car class code compatible with online compiler
class Car:
    def __init__(self, make, model, year): # Fixed init method
        self.make = make
        self.model = model
        self.year = year
    def start(self):
        print("The", self.year, self.make, self.model, "is starting.")
    def stop(self):
        print("The", self.year, self.make, self.model, "is stopping.")

car1 = Car("Toyota", "Camry", 2022)
car2 = Car("Honda", "Civic", 2032)

car1.start()
car2.stop()
OUTPUT:
The 2022 Toyota Camry is starting.
The 2032 Honda Civic is stopping.
